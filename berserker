def vaelin(name: str = "Vaelin") -> BloodSinger:
    """The Blood Singer -- full talent set like Vaelin Al Sorna."""
    return BloodSinger(name=name, talents=[
        Talent.STEEL, Talent.SIGHT, Talent.DEATH
    ])

def keeper_song(name: str = "Keeper") -> BloodSinger:
    """The Keeper's seventh sense -- intuition + structural awareness."""
    return BloodSinger(name=name, talents=[
        Talent.SIGHT, Talent.STONE, Talent.BEAST, Talent.DEATH
    ])

def shadow_agent(name: str = "Shadow") -> BloodSinger:
    """A stealth operative."""
    return BloodSinger(name=name, talents=[Talent.SHADOW, Talent.STEEL])

def healer(name: str = "Healer") -> BloodSinger:
    """A system repair specialist."""
    return BloodSinger(name=name, talents=[Talent.HEALING, Talent.SIGHT])

def tower_lord(name: str = "Tower Lord") -> BloodSinger:
    """The Tower Lord -- all talents awakened, like the final Vaelin."""
    return BloodSinger(name=name, talents=list(Talent))


