@dataclass
class MetalReserve:
    metal: Metal
    reserve: float = 0.0
    max_reserve: float = 100.0
    burning: bool = False
    flaring: bool = False
    drain_rate: float = 1.0

    @property
    def pct(self) -> float:
        return (self.reserve / self.max_reserve * 100) if self.max_reserve > 0 else 0

    @property
    def state_str(self) -> str:
        if self.flaring: return "FLARING"
        if not self.burning: return "idle"
        p = self.pct
        if p <= 0: return "EMPTY"
        if p < 25: return "low"
        if p < 75: return "moderate"
        return "full"


class Allomancer:
    def __init__(self, name: str, metals: Optional[List[Metal]] = None,
                 mistborn: bool = False):
        self.name = name
        self.mistborn = mistborn
        self.reserves: Dict[Metal, MetalReserve] = {}
        self.burn_log: List[Dict] = []
        target_metals = list(Metal) if mistborn else (metals or [])
        for metal in target_metals:
            info = METAL_INFO.get(metal, {})
            self.reserves[metal] = MetalReserve(
                metal=metal, reserve=info.get("max", 50),
                max_reserve=info.get("max", 50), drain_rate=info.get("drain", 1))

    def burn(self, metal: Metal) -> Dict:
        if metal not in self.reserves:
            return {"success": False, "reason": f"{self.name} cannot burn {metal.value}"}
        r = self.reserves[metal]
        if r.reserve <= 0:
            return {"success": False, "reason": f"{metal.value} empty"}
        r.burning = True; r.flaring = False
        info = METAL_INFO.get(metal, {})
        entry = {"success": True, "metal": metal.value, "power": info.get("power", "?")}
        self.burn_log.append(entry)
        return entry

    def flare(self, metal: Metal) -> Dict:
        if metal not in self.reserves:
            return {"success": False, "reason": f"Cannot flare {metal.value}"}
        r = self.reserves[metal]
        if r.reserve <= 0:
            return {"success": False, "reason": f"{metal.value} empty"}
        r.burning = True; r.flaring = True
        info = METAL_INFO.get(metal, {})
        return {"success": True, "metal": metal.value, "power": info.get("power","?") + " (FLARED)"}

    def extinguish(self, metal: Metal):
        if metal in self.reserves:
            self.reserves[metal].burning = False
            self.reserves[metal].flaring = False

    def extinguish_all(self):
        for r in self.reserves.values():
            r.burning = False; r.flaring = False

    def tick(self) -> List[Dict]:
        effects = []
        for metal, r in self.reserves.items():
            if r.burning and r.reserve > 0:
                drain = r.drain_rate * (3 if r.flaring else 1)
                r.reserve = max(0, r.reserve - drain)
                info = METAL_INFO.get(metal, {})
                effect = {"metal": metal.value, "power": info.get("power","?"),
                         "flaring": r.flaring, "remaining_pct": r.pct}
                if r.reserve <= 0:
                    r.burning = False; r.flaring = False
                    effect["exhausted"] = True
                effects.append(effect)
        return effects

    def swallow(self, metal: Metal, amount: Optional[float] = None):
        if metal not in self.reserves: return
        r = self.reserves[metal]
        r.reserve = r.max_reserve if amount is None else min(r.max_reserve, r.reserve + amount)

    def swallow_all(self):
        for r in self.reserves.values(): r.reserve = r.max_reserve

    def burning_metals(self) -> List[str]:
        return [m.value for m, r in self.reserves.items() if r.burning]

    def burn_aluminum(self) -> Dict:
        purged = []
        for metal, r in self.reserves.items():
            if metal != Metal.ALUMINUM and r.burning:
                purged.append(metal.value)
                r.burning = False; r.flaring = False; r.reserve = 0
        if Metal.ALUMINUM in self.reserves:
            self.reserves[Metal.ALUMINUM].reserve = 0
        return {"success": True, "purged": purged}

    def burn_duralumin(self, target_metal: Metal) -> Dict:
        if Metal.DURALUMIN not in self.reserves:
            return {"success": False, "reason": "No duralumin"}
        if target_metal not in self.reserves or not self.reserves[target_metal].burning:
            return {"success": False, "reason": f"{target_metal.value} not burning"}
        info = METAL_INFO.get(target_metal, {})
        self.reserves[Metal.DURALUMIN].reserve = 0
        self.reserves[Metal.DURALUMIN].burning = False
        self.reserves[target_metal].reserve = 0
        self.reserves[target_metal].burning = False
        return {"success": True, "amplified": True, "metal": target_metal.value,
                "message": f"DURALUMIN BURST: {info.get('power','?')} x10 -- both metals consumed"}

    def burn_lerasium(self) -> Dict:
        if Metal.LERASIUM not in self.reserves or self.reserves[Metal.LERASIUM].reserve <= 0:
            return {"success": False, "reason": "No lerasium"}
        self.reserves[Metal.LERASIUM].reserve = 0
        self.mistborn = True
        for metal in Metal:
            if metal not in self.reserves:
                info = METAL_INFO.get(metal, {})
                self.reserves[metal] = MetalReserve(
                    metal=metal, reserve=info.get("max", 50),
                    max_reserve=info.get("max", 50), drain_rate=info.get("drain", 1))
        return {"success": True, "message": f"{self.name} burned lerasium. Mistborn."}

    def burn_chromium(self, target: "Allomancer") -> Dict:
        if Metal.CHROMIUM not in self.reserves:
            return {"success": False, "reason": "No chromium"}
        drained = []
        for metal, r in target.reserves.items():
            if r.reserve > 0:
                drained.append(metal.value)
                r.reserve = 0; r.burning = False; r.flaring = False
        self.reserves[Metal.CHROMIUM].reserve = max(0, self.reserves[Metal.CHROMIUM].reserve - 5)
        return {"success": True, "drained": drained, "target": target.name}

    def reserves_display(self) -> str:
        lines = [f"  -- {self.name}'s Reserves --", ""]
        for metal in sorted(self.reserves.keys(), key=lambda m: m.value):
            r = self.reserves[metal]
            info = METAL_INFO.get(metal, {})
            filled = int(r.pct / 100 * 15)
            bar = "#" * filled + "." * (15 - filled)
            mark = "!" if r.flaring else "*" if r.burning else " "
            lines.append(f"  {mark} {info.get('name',metal.value):<10} [{bar}] {r.pct:5.1f}% {r.state_str:<10} {info.get('power','?')}")
        burning = self.burning_metals()
        lines.append(f"\n  Active: {', '.join(burning) if burning else 'none'}")
        return "\n".join(lines)


