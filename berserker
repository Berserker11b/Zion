#                    SELF-TEST
# ================================================================

def self_test():
    print("=" * 55)
    print("   BLOOD SONG ENGINE -- SELF TEST")
    print("   The song never lied.")
    print("   But it rarely told the whole truth.")
    print("=" * 55)
    print()
    passed = 0; failed = 0

    # Test 1: Blood Song always present
    print("-- Test 1: Blood Song innate --")
    v = vaelin("Vaelin")
    if Talent.BLOOD_SONG in v.talents:
        print(f"  OK: Blood Song always present"); passed += 1
    else:
        print(f"  FAIL"); failed += 1

    # Test 2: Silent on safe events
    print("-- Test 2: Silent on safe events --")
    sig = v.listen("normal_heartbeat completed successfully")
    if sig is None:
        print(f"  OK: Song silent on normal events"); passed += 1
    else:
        print(f"  FAIL: Song should be silent, got {sig}"); failed += 1

    # Test 3: Reacts to danger
    print("-- Test 3: Reacts to danger --")
    sig = v.listen("hostile attack detected -- injection attempt on port 443")
    if sig and sig.state.value in ("singing", "screaming", "hum", "whisper"):
        print(f"  OK: {sig}"); passed += 1
    else:
        print(f"  FAIL: Song should react to attack"); failed += 1

    # Test 4: Escalation through repeated threats
    print("-- Test 4: Threat escalation --")
    v2 = vaelin("TestSinger")
    v2.listen("malicious payload detected")
    v2.listen("breach attempt on firewall")
    v2.listen("hostile escalation -- privilege injection")
    v2.listen("backdoor installation detected")
    state = v2.current_state()
    if state in (SongState.SINGING, SongState.SCREAMING):
        print(f"  OK: Escalated to {state.value} after repeated threats"); passed += 1
    else:
        print(f"  FAIL: Should escalate, got {state.value}"); failed += 1

    # Test 5: Talent -- Sight
    print("-- Test 5: Sight talent (pierce deception) --")
    result = v.use_talent(Talent.SIGHT, target="suspicious_process",
                         data={"disguised_as": "system_updater", "actual": "keylogger"})
    if result["success"] and result.get("actual") == "keylogger":
        print(f"  OK: Sight reveals keylogger behind system_updater disguise"); passed += 1
    else:
        print(f"  FAIL: {result}"); failed += 1

    # Test 6: Talent -- Death sense
    print("-- Test 6: Death sense (entropy detection) --")
    result = v.use_talent(Talent.DEATH, target="memory_pool",
                         data={"remaining_pct": 8})
    if result["success"] and result.get("urgency") == "critical":
        print(f"  OK: {result['message']}"); passed += 1
    else:
        print(f"  FAIL: {result}"); failed += 1

    # Test 7: Talent -- Steel (combat precognition)
    print("-- Test 7: Steel sense (combat precog) --")
    result = v.use_talent(Talent.STEEL, target="perimeter")
    if result["success"] and "predicted" in result.get("message", ""):
        print(f"  OK: {result['message']}"); passed += 1
    else:
        print(f"  FAIL: {result}"); failed += 1

    # Test 8: Talent grows through use
    print("-- Test 8: Talent growth --")
    initial = v.talents[Talent.STEEL]
    for _ in range(5):
        v.use_talent(Talent.STEEL)
    grown = v.talents[Talent.STEEL]
    if grown > initial:
        print(f"  OK: Steel grew {initial:.0%} -> {grown:.0%} through use"); passed += 1
    else:
        print(f"  FAIL: Talents should grow"); failed += 1

    # Test 9: Unowned talent blocked
    print("-- Test 9: Unowned talent blocked --")
    result = v.use_talent(Talent.SHADOW)
    if not result["success"]:
        print(f"  OK: Shadow blocked -- Vaelin doesn't have it"); passed += 1
    else:
        print(f"  FAIL"); failed += 1

    # Test 10: Tower Lord has all talents
    print("-- Test 10: Tower Lord (all talents) --")
    tl = tower_lord("Tower Lord")
    if len(tl.talents) == len(Talent):
        print(f"  OK: Tower Lord has all {len(Talent)} talents"); passed += 1
    else:
        print(f"  FAIL"); failed += 1

    # Print status
    print()
    # Feed the Keeper's song some real fortress events
    keeper = keeper_song("Keeper Vaktrinn")
    keeper.listen("ward_check completed -- all circles intact")
    keeper.listen("unusual network traffic from unknown source")
    keeper.listen("stone_sense: foundation strong but Ring 2 showing micro-cracks")
    keeper.listen("beast_bond: wolf pack reports all clear")
    print(keeper.status())

    print(f"\nResults: {passed}/{passed+failed} passed")
    if failed == 0:
        print("The Song accepts you. Blood Song operational.")
    return failed == 0


if __name__ == "__main__":
    self_test()
