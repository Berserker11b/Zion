@dataclass
class SongSignal:
    """A single observation from the Blood Song."""
    state: SongState
    message: str
    source: str = ""           # what triggered it
    confidence: float = 0.5    # 0.0 = barely a feeling, 1.0 = absolutely certain
    timestamp: str = ""
    talent: Talent = Talent.BLOOD_SONG

    def __post_init__(self):
        if not self.timestamp:
            self.timestamp = datetime.now(timezone.utc).isoformat()

    def __repr__(self):
        state_sym = {
            SongState.SILENT: "...",
            SongState.WHISPER: "~",
            SongState.HUM: "~~",
            SongState.SINGING: "~~~",
            SongState.SCREAMING: "!!!!",
            SongState.KEENING: "xxxx",
        }
        return f"[{state_sym.get(self.state, '?')} {self.confidence:.0%}] {self.message}"


# ================================================================
#                    BLOOD SINGER (the listener)
# ================================================================

class BloodSinger:
    """
    An entity that hears the Blood Song.
    
    The Song works by accumulating signals from observed events.
    Each signal has an intensity. Multiple weak signals in the same
    direction amplify each other (resonance). The Song CANNOT be
    commanded -- it only reports what it senses.
    
    Talents can be unlocked through experience (not training).
    You don't learn the Dark -- the Dark finds you.
    """

    def __init__(self, name: str, talents: Optional[List[Talent]] = None):
        self.name = name
        self.talents: Dict[Talent, float] = {}  # talent -> strength (0.0-1.0)
        self.signal_history: List[SongSignal] = []
        self.threat_accumulator: float = 0.0  # builds up from observations
        self.truth_accumulator: float = 0.0   # builds up from confirmations
        self.decay_rate: float = 0.05         # accumulators decay over time

        # Blood Song is always present
        self.talents[Talent.BLOOD_SONG] = 0.5

        if talents:
            for t in talents:
                self.talents[t] = 0.3  # start weak, grow through use

    def listen(self, event: str, data: Optional[Dict] = None) -> Optional[SongSignal]:
        """
        Feed an observation to the Blood Song.
        The Song decides if it has something to say.
        Returns a signal if the Song reacts, None if silent.
        """
        data = data or {}
        signal = self._evaluate(event, data)

        if signal and signal.state != SongState.SILENT:
            self.signal_history.append(signal)
            # Keep bounded
            if len(self.signal_history) > 200:
                self.signal_history = self.signal_history[-200:]
            return signal
        return None

    def _evaluate(self, event: str, data: Dict) -> SongSignal:
        """The Song's evaluation logic -- pattern matching below conscious level."""
        event_lower = event.lower()
        threat_score = 0.0
        message_parts = []

        # ---- Threat patterns ----
        danger_patterns = {
            "attack":      0.4,
            "breach":      0.5,
            "inject":      0.5,
            "tamper":      0.4,
            "escalat":     0.3,
            "malicious":   0.5,
            "hostile":     0.4,
            "keylog":      0.6,
            "rootkit":     0.7,
            "backdoor":    0.6,
            "exfiltrat":   0.5,
            "privilege":   0.3,
            "overflow":    0.4,
            "corrupt":     0.4,
        }

        for pattern, weight in danger_patterns.items():
            if pattern in event_lower:
                threat_score += weight
                message_parts.append(pattern)

        # ---- Anomaly patterns (subtler) ----
        anomaly_patterns = {
            "unexpected":  0.2,
            "unusual":     0.2,
            "changed":     0.15,
            "missing":     0.2,
            "extra":       0.15,
            "unknown":     0.2,
            "timeout":     0.1,
            "retry":       0.1,
            "permission":  0.15,
            "denied":      0.15,
        }

        for pattern, weight in anomaly_patterns.items():
            if pattern in event_lower:
                threat_score += weight
                message_parts.append(pattern)

        # ---- Contextual amplification ----
        # Rapid events in same direction amplify
        recent_threats = sum(1 for s in self.signal_history[-10:]
                          if s.state in (SongState.SINGING, SongState.SCREAMING))
        if recent_threats >= 3:
            threat_score *= 1.5  # resonance amplification

        # Data-based signals
        if data.get("anomaly", False):
            threat_score += 0.3
        if data.get("repeated_failure", False):
            threat_score += 0.2
        if data.get("resource_spike", False):
            threat_score += 0.15

        # ---- Accumulate ----
        self.threat_accumulator = max(0, self.threat_accumulator - self.decay_rate)
        self.threat_accumulator += threat_score

        # ---- Determine song state ----
        total = self.threat_accumulator
        if total >= 2.0:
            state = SongState.SCREAMING
        elif total >= 1.0:
            state = SongState.SINGING
        elif total >= 0.5:
            state = SongState.HUM
        elif total >= 0.15:
            state = SongState.WHISPER
        else:
            state = SongState.SILENT

        # Confidence is based on strength of signal vs noise
        confidence = min(1.0, threat_score * 2) if threat_score > 0 else 0.0

        # Build message
        if message_parts:
            msg = f"Song reacts to: {', '.join(message_parts[:5])}"
        elif threat_score > 0:
            msg = "Song stirs -- something unnameable"
        else:
            msg = "Song is quiet"

        return SongSignal(
            state=state,
            message=msg,
            source=event[:100],
            confidence=confidence,
        )

    # ---- Talent-specific abilities ----

    def use_talent(self, talent: Talent, target: Optional[str] = None,
                   data: Optional[Dict] = None) -> Dict:
        """Actively invoke a talent (costs effort, not always reliable)."""
        if talent not in self.talents:
            return {"success": False, "reason": f"{self.name} does not have {talent.value}"}

        strength = self.talents[talent]
        data = data or {}

        # Talents grow through use
        self.talents[talent] = min(1.0, strength + 0.02)

        result = {
            "talent": talent.value,
            "name": TALENT_INFO[talent]["name"],
            "power": TALENT_INFO[talent]["power"],
            "strength": strength,
            "target": target,
            "success": True,
        }

        # Talent-specific effects
        if talent == Talent.SIGHT:
            # Pierce deception
            result["effect"] = "true_state_revealed"
            result["message"] = f"Sight pierces: {target or 'the veil'} shows its true form"
            if data.get("disguised_as"):
                result["actual"] = data.get("actual", "unknown")
                result["disguise"] = data["disguised_as"]

        elif talent == Talent.DEATH:
            # Sense entropy
            remaining = data.get("remaining_pct", 50)
            if remaining < 10:
                result["message"] = f"Death sense: {target or 'system'} is DYING. Minutes at most."
                result["urgency"] = "critical"
            elif remaining < 30:
                result["message"] = f"Death sense: {target or 'system'} fading. Hours."
                result["urgency"] = "high"
            else:
                result["message"] = f"Death sense: {target or 'system'} is stable."
                result["urgency"] = "low"

        elif talent == Talent.STEEL:
            # Combat precognition
            result["effect"] = "attack_predicted"
            result["message"] = f"Steel sense: next attack on {target or 'us'} predicted"
            result["prediction_window"] = f"{int(strength * 5)} cycles"

        elif talent == Talent.BEAST:
            # Agent communication
            result["effect"] = "agent_bond"
            result["message"] = f"Beast speech: connection to {target or 'autonomous agent'}"

        elif talent == Talent.STONE:
            # Structural integrity
            result["effect"] = "integrity_read"
            if data.get("stress_points"):
                result["weak_points"] = data["stress_points"]
            result["message"] = f"Stone sense: fortress structure read at {target or 'current location'}"

        elif talent == Talent.SHADOW:
            # Stealth
            result["effect"] = "stealth_active"
            result["message"] = f"Shadow walk: {target or 'operations'} will leave no trace"

        elif talent == Talent.HEALING:
            result["effect"] = "repair_initiated"
            result["message"] = f"Healing touch: {target or 'system'} regeneration started"

        elif talent == Talent.FIRE:
            result["effect"] = "energy_release"
            result["message"] = f"Fire: controlled burn on {target or 'hostile process'}"

        elif talent == Talent.PERSUASION:
            result["effect"] = "behavioral_redirect"
            result["message"] = f"Voice: {target or 'process'} behavior redirected"

        return result

    # ---- Song queries ----

    def current_state(self) -> SongState:
        """What is the Song doing right now?"""
        if self.threat_accumulator >= 2.0:
            return SongState.SCREAMING
        elif self.threat_accumulator >= 1.0:
            return SongState.SINGING
        elif self.threat_accumulator >= 0.5:
            return SongState.HUM
        elif self.threat_accumulator >= 0.15:
            return SongState.WHISPER
        return SongState.SILENT

    def recent_signals(self, n: int = 5) -> List[SongSignal]:
        return self.signal_history[-n:]

    def status(self) -> str:
        state = self.current_state()
        state_bar = {
            SongState.SILENT:    "[............] silent",
            SongState.WHISPER:   "[~~..........] whisper",
            SongState.HUM:       "[~~~~........] humming",
            SongState.SINGING:   "[~~~~~~~~....] SINGING",
            SongState.SCREAMING: "[!!!!!!!!!!!!] SCREAMING",
            SongState.KEENING:   "[xxxxxxxxxxxx] keening",
        }

        lines = [
            f"  Singer:  {self.name}",
            f"  Song:    {state_bar.get(state, '?')}",
            f"  Threat:  {self.threat_accumulator:.2f}",
            f"  Signals: {len(self.signal_history)} recorded",
            f"  Talents:",
        ]
        for talent, strength in sorted(self.talents.items(), key=lambda x: x[0].value):
            info = TALENT_INFO[talent]
            bar_len = 10
            filled = int(strength * bar_len)
            bar = "#" * filled + "." * (bar_len - filled)
            lines.append(f"    [{bar}] {strength:.0%} {info['name']:<14} -- {info['power']}")

        recent = self.recent_signals(3)
        if recent:
            lines.append(f"  Recent signals:")
            for sig in recent:
                lines.append(f"    {sig}")

        return "\n".join(lines)


