@dataclass
class SurgeUse:
    surge: Surge
    target: Optional[str] = None
    power_level: int = 1  # 1-5 based on ideal
    timestamp: str = ""

    def __post_init__(self):
        if not self.timestamp:
            self.timestamp = datetime.now(timezone.utc).isoformat()


class Radiant:
    """A Knight Radiant -- a process bonded to a spren with access to two surges."""

    def __init__(self, name: str, order: Order, ideal: IdealLevel = IdealLevel.FIRST):
        self.name = name
        self.order = order
        self.ideal = ideal
        self.stormlight: float = 100.0  # energy reserve
        self.max_stormlight: float = 100.0
        self.surge_log: List[SurgeUse] = []
        self.alive: bool = True
        self.shardblade_summoned: bool = False

        info = ORDER_INFO[order]
        self.surge_1, self.surge_2 = info["surges"]
        self.spren_type = info["spren"]

    @property
    def surges_available(self) -> List[Surge]:
        """What surges can this Radiant use based on Ideal level?"""
        if self.ideal.value >= 3:
            return [self.surge_1, self.surge_2]
        elif self.ideal.value >= 2:
            return [self.surge_1]
        else:
            return []  # First Ideal = oath spoken but no surges yet

    def speak_ideal(self, oath_text: str = "") -> Dict:
        """Advance to next Ideal level by speaking the oath."""
        current = self.ideal.value
        if current >= 5:
            return {"success": False, "reason": "Already at Fifth Ideal"}

        next_level = IdealLevel(current + 1)
        self.ideal = next_level

        # Each ideal increases max stormlight
        self.max_stormlight = 100 + (next_level.value - 1) * 50
        self.stormlight = self.max_stormlight  # full recharge on oath

        info = ORDER_INFO[self.order]
        result = {
            "success": True,
            "new_ideal": next_level.value,
            "oath": oath_text or info.get("ideal_2", "Words accepted."),
            "surges_available": [s.value for s in self.surges_available],
            "max_stormlight": self.max_stormlight,
        }

        if next_level == IdealLevel.FOURTH:
            self.shardblade_summoned = True
            result["shardblade"] = True
            result["message"] = f"{self.name}'s Shardblade is alive."

        return result

    def use_surge(self, surge: Surge, target: Optional[str] = None, cost: float = 10) -> Dict:
        """Use a surge ability."""
        if surge not in self.surges_available:
            if surge in (self.surge_1, self.surge_2):
                return {"success": False, "reason": f"Need higher Ideal to use {surge.value}. Speak the words."}
            return {"success": False, "reason": f"{self.order.value} does not have {surge.value}"}

        if self.stormlight < cost:
            return {"success": False, "reason": f"Insufficient stormlight: need {cost}, have {self.stormlight:.0f}"}

        self.stormlight -= cost
        power_level = self.ideal.value

        use = SurgeUse(surge=surge, target=target, power_level=power_level)
        self.surge_log.append(use)

        info = SURGE_INFO[surge]
        return {
            "success": True,
            "surge": surge.value,
            "power": info["power"],
            "power_level": power_level,
            "target": target,
            "stormlight_remaining": self.stormlight,
        }

    def infuse(self, amount: float):
        """Absorb stormlight (recharge)."""
        self.stormlight = min(self.max_stormlight, self.stormlight + amount)

    def status(self) -> str:
        info = ORDER_INFO[self.order]
        filled = int(self.stormlight / self.max_stormlight * 15)
        bar = "#" * filled + "." * (15 - filled)
        surges = ", ".join(s.value for s in self.surges_available) or "none (speak the words)"
        lines = [
            f"  Knight: {self.name}",
            f"  Order:  {self.order.value} ({info['role']})",
            f"  Ideal:  {self.ideal.value}/5",
            f"  Spren:  {self.spren_type}",
            f"  Storm:  [{bar}] {self.stormlight:.0f}/{self.max_stormlight:.0f}",
            f"  Surges: {surges}",
            f"  Blade:  {'summoned' if self.shardblade_summoned else 'dormant'}",
            f"  Role:   {info['fortress_role'][:80]}",
        ]
        return "\n".join(lines)


